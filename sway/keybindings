set $term foot
set $browser firefox
set $menu wmenu-run -l 10 -p Run
set $lock swaylock

floating_modifier Mod1

bindsym Ctrl+Mod1+t exec $term
bindsym Mod1+d exec $menu
bindsym Mod1+Shift+b exec $browser
bindsym Ctrl+Shift+d kill

bindsym Mod1+0 workspace number 10
bindsym Mod1+1 workspace number 1
bindsym Mod1+2 workspace number 2
bindsym Mod1+3 workspace number 3
bindsym Mod1+4 workspace number 4
bindsym Mod1+5 workspace number 5
bindsym Mod1+6 workspace number 6
bindsym Mod1+7 workspace number 7
bindsym Mod1+8 workspace number 8
bindsym Mod1+9 workspace number 9
bindsym Mod1+Shift+0 move container to workspace number 10
bindsym Ctrl+Shift+1 move container to workspace number 1
bindsym Ctrl+Shift+2 move container to workspace number 2
bindsym Mod1+Shift+3 move container to workspace number 3
bindsym Mod1+Shift+4 move container to workspace number 4
bindsym Mod1+Shift+5 move container to workspace number 5
bindsym Mod1+Shift+6 move container to workspace number 6
bindsym Mod1+Shift+7 move container to workspace number 7
bindsym Mod1+Shift+8 move container to workspace number 8
bindsym Mod1+Shift+9 move container to workspace number 9

bindsym Mod1+Shift+c reload
bindsym Mod1+Shift+r restart
bindsym Mod1+Shift+e exec swaynag -t warning -m 'Do you really want to exit sway?' -b 'Yes, exit sway' 'swaymsg exit'

bindsym Mod1+minus scratchpad show
bindsym Mod1+Shift+minus move scratchpad

bindsym Mod1+Shift+p mode passthrough
bindsym Mod1+r mode resize

bindsym Mod1+e layout toggle split
bindsym Mod1+v splitv
bindsym Mod1+b splith

bindsym Mod1+f fullscreen toggle
bindsym Mod1+Shift+space floating toggle
bindsym Mod1+space focus mode_toggle

bindsym Mod1+s layout stacking
bindsym Mod1+w layout tabbed

# Special Keys:
bindsym Print exec grim -g "$(slurp -d)" - | wl-copy
bindsym XF86AudioMicMute exec pulsemixer --set-mute $(pulsemixer --list-sources | grep 'default' | awk '{print $1}') toggle
bindsym XF86AudioMute exec pulsemixer --toggle-mute
bindsym XF86AudioLowerVolume exec pulsemixer --change-volume -5
bindsym XF86AudioRaiseVolume exec pulsemixer --change-volume +5
bindsym XF86MonBrightnessDown exec brightnessctl set 1%-
bindsym XF86MonBrightnessUp exec brightnessctl set 1%+


bindsym Ctrl+Left  move left
bindsym Ctrl+Right move right
bindsym Ctrl+Up    move up
bindsym Ctrl+Down  move down
bindsym Shift+Left  exec ~/.config/sway/focus_or_workspace.sh left
bindsym Shift+Right exec ~/.config/sway/focus_or_workspace.sh right
bindsym Shift+Up    exec ~/.config/sway/focus_or_workspace.sh up
bindsym Shift+Down  exec ~/.config/sway/focus_or_workspace.sh down


mode "passthrough" {
	bindsym Mod1+Shift+p mode default
}

mode "resize" {
	bindsym Return mode default
	bindsym Escape mode default

	bindsym h resize shrink width 10px
	bindsym j resize grow height 10px
	bindsym k resize shrink height 10px
	bindsym l resize grow width 10px
}


